#include <stdio.h>
#include <ctype.h>

int main(void) {
    char file_name[100];
    int characters = 0, words = 0;
    int ch;            // char → int
    int in_word = 0;

    printf("파일 이름: ");
    scanf("%99s", file_name);

    FILE* fp = fopen(file_name, "r");
    if (fp == NULL) {
        printf("파일 %s을 열 수 없습니다.\n", file_name);
        return 1;
    }

    while ((ch = fgetc(fp)) != EOF) {
        characters++;
        if (isspace(ch) || ispunct(ch)) {
            in_word = 0;
        }
        else if (!in_word) {
            in_word = 1;
            words++;
        }
    }

    printf("문자의 개수는 %d\n", characters);
    printf("단어의 개수는 %d\n", words);

    fclose(fp);
    return 0;
}
