#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(void)
{
    FILE *fp1;
    char file1[100];
    char buffer[1000];
    int ch;

    printf("파일 이름을 입력하시오: ");
    scanf("%99s", file1);

    // scanf가 남긴 개행 문자 제거
    while ((ch = getchar()) != '\n' && ch != EOF)
        ;

    if ((fp1 = fopen(file1, "w")) == NULL)
    {
        fprintf(stderr, "파일 %s을 열 수 없습니다.\n", file1);
        exit(1);
    }

    printf("\n");

    while (fgets(buffer, sizeof(buffer), stdin) != NULL)
    {
        buffer[strcspn(buffer, "\n")] = '\0';  // 줄 끝의 \n 제거
        fprintf(fp1, "%s\n", buffer);
    }

    fclose(fp1);
    return 0;
}
