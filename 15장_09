#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(void)
{
    FILE *fp1, *fp2;
    char file1[100], file2[100];
    char buffer[100];

    printf("입력 파일 이름: ");
    scanf("%99s", file1);

    printf("출력 파일 이름: ");
    scanf("%99s", file2);

    // 첫번째 파일을 읽기 모드로 연다.
    if ((fp1 = fopen(file1, "r")) == NULL)
    {
        fprintf(stderr, "파일 %s을 열 수 없습니다.\n", file1);
        exit(1);
    }

    // 두번째 파일을 쓰기 모드로 연다.
    if ((fp2 = fopen(file2, "w")) == NULL)
    {
        fprintf(stderr, "파일 %s을 열 수 없습니다.\n", file2);
        fclose(fp1);
        exit(1);
    }

    // Android를 안드로이드로 바꾸면서 복사한다.
    while (fgets(buffer, sizeof(buffer), fp1) != NULL)
    {
        buffer[strcspn(buffer, "\n")] = '\0';   // 줄 끝의 \n 제거

        char *pos = strtok(buffer, " ");
        int first = 1;                          // 줄의 첫 단어인지 표시

        while (pos != NULL)
        {
            if (!first)
                fprintf(fp2, " ");              // 단어 사이에만 공백
            first = 0;

            if (strcmp("Android", pos) == 0)
                fprintf(fp2, "안드로이드");
            else
                fprintf(fp2, "%s", pos);

            pos = strtok(NULL, " ");
        }
        fprintf(fp2, "\n");                     // 줄바꿈 복원
    }

    fclose(fp1);
    fclose(fp2);
    return 0;
}
